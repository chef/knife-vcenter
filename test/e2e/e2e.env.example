# Copy this file's contents into your shell (do NOT commit real credentials)
# and adjust as needed, then run:
#
#   source my-e2e.env
#   ./test/e2e/run_e2e_tests.sh
#
# Only VCENTER_PASSWORD is strictly required; everything else has a default
# baked into run_e2e_tests.sh matching the standard lab environment. Override
# anything below that differs for your environment.

# --- Required ---
export VCENTER_PASSWORD='changeme'

# --- vCenter connection (defaults shown match the standard lab) ---
export VCENTER_HOST='vschefvc01.bedford.progress.com'
export VCENTER_USERNAME='asaidala@bedford.progress.com'
export DATACENTER='Marlborough'
export TARGETHOST='vschefvc01-vesx1.bedford.progress.com'
export FOLDER='vm'
export POOL='Resources'

# --- vm create only (leave unset to skip TC10/TC11 - see README) ---
# export DATASTORE='datastore1'

# --- Templates used for vm clone ---
export LINUX_TEMPLATE='Templates/debian-13.3.0-amd64'
export WINDOWS_TEMPLATE='Templates/windows2022'

# --- Guest OS credentials used for the post-clone bootstrap connection ---
export LINUX_CONNECTION_USER='progress'
export LINUX_CONNECTION_PASSWORD='p@ssW0rd!'
export WINDOWS_CONNECTION_USER='Administrator'
export WINDOWS_CONNECTION_PASSWORD='p@ssW0rd!'

# --- Chef Infra Client major versions to validate (space separated) ---
export LINUX_CHEF_VERSIONS='18 19'
export WINDOWS_CHEF_VERSIONS='18 19'

# --- Timeouts, in seconds ---
export LIST_TIMEOUT=120
export SHOW_TIMEOUT=60
export DELETE_TIMEOUT=180
export BOOTSTRAP_TIMEOUT=1200
export CREATE_TIMEOUT=300
